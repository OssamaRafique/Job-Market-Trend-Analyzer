# Copy to .env for local development. Never commit the real .env.

# Postgres connection string. When running via docker-compose, host is "postgres".
# When pointing at Fly Postgres, use the value from `flyctl postgres attach`.
DATABASE_URL=postgresql://jmta:dev@postgres:5432/jmta

# RabbitMQ. When running via docker-compose, host is "rabbitmq".
AMQP_URL=amqp://guest:guest@rabbitmq:5672/

# The Muse API base URL (stable; exposed as a var so tests can point elsewhere).
MUSE_API_URL=https://www.themuse.com/api/public/jobs

# How many pages per category the collector fetches per run.
COLLECTOR_PAGES=5
